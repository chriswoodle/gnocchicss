{
    "compilerOptions": {
        "composite": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ESNext",
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "lib": [
            "esnext"
        ],
        "types": [
            "node"
        ]
    },
    "references": [
        {
            "path": "../core"
        },
        {
            "path": "../gnocchicss"
        }
    ]
}
